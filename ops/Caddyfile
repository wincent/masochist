# Import optional config fragments (eg. domain redirects in prod).
import /etc/caddy/conf.d/*

{$SITE_ADDRESS:localhost} {
	{$TLS_CONFIG}

	encode zstd gzip

	# Security headers.
	header {
		Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
		Permissions-Policy "geolocation=(), camera=(), microphone=()"
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
	}
	# HSTS only in prod — in dev SITE_ADDRESS is localhost, and HSTS on
	# localhost would force HTTPS for all localhost traffic in the browser,
	# breaking other local services using plain HTTP.
	@prod host wincent.dev
	header @prod Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# Import redirect rules generated by the build.
	import /var/www/public/_redirects.caddy

	# Import optional includes (eg. shortlinks managed by Ansible).
	import /etc/caddy/includes/*

	# Serve hashed assets with long-lived cache.
	handle /_assets/* {
		root * /var/www/public
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Icons are stable static SVGs referenced from CSS.
	handle /icons/* {
		root * /var/www/public
		header Cache-Control "public, max-age=31536000"
		file_server
	}

	# Hide other internal build artifacts (prefixed with underscore).
	@hidden path /_*
	handle @hidden {
		root * /var/www/public
		rewrite * /404.html
		file_server {
			status 404
		}
	}

	# Strip trailing slashes.
	@trailingSlash path_regexp ^/(.+)/$
	redir @trailingSlash /{re.trailingSlash.1} permanent

	# Raw snippet files (eg. /snippets/foo.sh).
	@rawSnippet path_regexp rawSnippet ^/snippets/[^/]+\.(patch|rb|sh|txt)$
	handle @rawSnippet {
		root * /var/www/public
		header Content-Type text/plain
		file_server
	}

	# Search is the only dynamic route — proxy to the Rocket app.
	handle /search* {
		reverse_proxy app:8000 {
			header_up X-Real-IP {remote_host}
			@badrequest status 400
			handle_response @badrequest {
				root * /var/www/public
				rewrite * /400.html
				file_server {
					status 400
				}
			}
			@ratelimited status 429
			handle_response @ratelimited {
				root * /var/www/public
				rewrite * /429.html
				file_server {
					status 429
				}
			}
		}
	}

	# Wiki paths with %3F: Go decodes it to ? in {path}, which try_files
	# re-interprets as a query separator. Bypass try_files for these.
	@wikiEncodedQuestion path_regexp weq ^(/wiki/.+)\?$
	handle @wikiEncodedQuestion {
		root * /var/www/public
		rewrite * {re.weq.1}%3F.html
		file_server
	}

	# Everything else is static.
	handle {
		root * /var/www/public

		route {
			# Try exact file, then .html extension, then index.html, then 404.
			try_files {path} {path}.html {path}/index.html {path}/index.php

			# Legacy .php files are static HTML; the Alpine image has no
			# MIME mapping for .php so Caddy omits Content-Type without this.
			@php path *.php
			header @php Content-Type "text/html; charset=utf-8"

			file_server
		}
	}

	handle_errors {
		root * /var/www/public
		rewrite * /404.html
		file_server
	}
}
