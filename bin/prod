#!/bin/bash
set -euo pipefail

if [ -z "${DD_API_KEY:-}" ] && [ -f "$HOME/.bashrc" ] && grep -q '^export DD_API_KEY=' "$HOME/.bashrc"; then
    eval "$(grep '^export DD_API_KEY=' "$HOME/.bashrc")"
fi

DEPLOY_DIR="/srv/masochist"
REPO="${DEPLOY_DIR}/repo"

# Check out ops/ and bin/prod from the main branch.
echo "Checking out ops/ and bin/prod from main..."
git --work-tree="${DEPLOY_DIR}" --git-dir="${REPO}" checkout main -- ops/ bin/prod
chmod +x "${DEPLOY_DIR}/bin/prod"

# Update static site content from the public branch.
echo "Checking out static site from public branch..."
git --work-tree="${DEPLOY_DIR}/public" --git-dir="${REPO}" checkout public -- .

OPS="${DEPLOY_DIR}/ops"

ECR_ACCOUNT_ID="${ECR_ACCOUNT_ID:-$(aws ecr describe-registry --region us-east-1 --query registryId --output text)}"

cat > "${DEPLOY_DIR}/ops/.env" <<EOF
APP_UID=$(id -u)
APP_GID=$(id -g)
ECR_ACCOUNT_ID=${ECR_ACCOUNT_ID}
DD_SITE=${DD_SITE:-datadoghq.com}
DD_API_KEY=${DD_API_KEY}
EOF

ECR_REGISTRY="${ECR_ACCOUNT_ID}.dkr.ecr.us-east-1.amazonaws.com"
aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin "${ECR_REGISTRY}"

docker-compose \
    -f "$OPS/compose.base.yml" \
    -f "$OPS/compose.prod.yml" \
    -f "$OPS/compose.ecr.yml" \
    -f "$OPS/compose.profiler.yml" \
    pull

docker-compose \
    -f "$OPS/compose.base.yml" \
    -f "$OPS/compose.prod.yml" \
    -f "$OPS/compose.ecr.yml" \
    -f "$OPS/compose.profiler.yml" \
    up -d --force-recreate
