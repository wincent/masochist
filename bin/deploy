#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

HOST="${MASOCHIST_HOST:-wincent.dev}"
DEPLOY_DIR="/srv/masochist"

# Warn if main hasn't been pushed to prod.
if git -C "${REPO_DIR}" rev-parse --verify masochist/main &>/dev/null; then
    LOCAL=$(git -C "${REPO_DIR}" rev-parse main)
    REMOTE=$(git -C "${REPO_DIR}" rev-parse masochist/main)
    if [ "$LOCAL" != "$REMOTE" ]; then
        echo "Warning: main is not up to date with masochist/main"
        echo "  local:  ${LOCAL}"
        echo "  remote: ${REMOTE}"
        echo "You may want to run: bin/push"
        echo
        read -r -p "Continue anyway? [y/N] " answer
        if [[ ! "$answer" =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
fi

# Check out bin/prod from the repo and run it.
echo "Pulling and restarting on ${HOST}..."
ssh "${HOST}" "sudo -u masochist git --work-tree=${DEPLOY_DIR} --git-dir=${DEPLOY_DIR}/repo checkout main -- bin/prod && sudo -u masochist chmod +x ${DEPLOY_DIR}/bin/prod && sudo -u masochist bash -c 'cd ${DEPLOY_DIR} && ECR_ACCOUNT_ID=${ECR_ACCOUNT_ID} ${DEPLOY_DIR}/bin/prod'"

# Tag the deployment after success.
TAG="deploy/$(date -u +%Y-%m-%d/%H.%M.%S)"
echo "Tagging: ${TAG}"
git -C "${REPO_DIR}" tag "${TAG}"

echo "Deploy complete."
