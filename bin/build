#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
OUTPUT_DIR="${REPO_DIR}/public"

echo "Building static site..."
cargo run --manifest-path "${REPO_DIR}/Cargo.toml" \
    --release --package masochist-build -- \
    "${REPO_DIR}" "${OUTPUT_DIR}"

echo ""
echo "Output: ${OUTPUT_DIR}"
echo "Files: $(find "${OUTPUT_DIR}" -type f | wc -l | tr -d ' ')"

echo ""
echo "Committing to public branch..."
git -C "${OUTPUT_DIR}" add -A
if git -C "${OUTPUT_DIR}" diff --cached --quiet; then
    echo "No changes to commit."
else
    git -C "${OUTPUT_DIR}" commit -m "build: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
    echo "Committed. Push with: git -C public push"
fi
