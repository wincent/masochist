#!/bin/bash
set -euo pipefail

ECR_REGION="us-east-1"
ECR_ACCOUNT_ID="${ECR_ACCOUNT_ID:-}"
ECR_REGISTRY="${ECR_ACCOUNT_ID}.dkr.ecr.${ECR_REGION}.amazonaws.com"

if [ -z "$ECR_ACCOUNT_ID" ]; then
    echo "Error: ECR_ACCOUNT_ID environment variable is required"
    echo
    echo "Example:"
    echo
    echo "    export ECR_ACCOUNT_ID=123456789012"
    echo
    echo "You can look up your account ID with:"
    echo
    echo "    aws ecr describe-registry --region ${ECR_REGION} --query registryId --output text"
    echo
    exit 1
fi

echo "Logging into Amazon ECR..."
aws ecr get-login-password --region "$ECR_REGION" | docker login --username AWS --password-stdin "$ECR_REGISTRY"

LOCAL_IMAGE="masochist-app:latest"
ECR_IMAGE="${ECR_REGISTRY}/masochist/app:latest"

echo "Tagging ${LOCAL_IMAGE} as ${ECR_IMAGE}"
docker tag "$LOCAL_IMAGE" "$ECR_IMAGE"

echo "Pushing ${ECR_IMAGE}"
docker push "$ECR_IMAGE"

echo "Upload complete."
